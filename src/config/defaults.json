{
  "grid": {
    "cellSize": 72,
    "gap": 16,
    "columns": {
      "mobile": 4,
      "tablet": 6,
      "desktop": 8
    }
  },
  "dock": {
    "slots": 4,
    "panelHeight": 100,
    "baseItemSize": 70,
    "magnification": 90
  },
  "fusion": {
    "preFusionDistance": 0.6,
    "fusionDistance": 0.3,
    "separationThreshold": 0.5
  },
  "animation": {
    "preFusionDuration": 150,
    "fusionDuration": 200,
    "fusionEasing": "cubic-bezier(0.34, 1.56, 0.64, 1)",
    "separationDuration": 300
  },
  "overlay": {
    "opacity": 0.3
  },
  "wallpaper": "https://images.unsplash.com/photo-1506744038136-46273834b3fb?w=1920&q=80"
}
